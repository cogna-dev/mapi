///|
let generated_header = "// Code generated by mapi. DO NOT EDIT.\n"

///|
let user_header = "// User-owned file. Safe from regeneration.\n"

///|
fn generate_project(ir : ApiIR, module_name : String) -> Map[String, String] {
  let files = {}
  files["moon.mod.json"] = generate_moon_mod(module_name)
  files["src/generated/moon.pkg"] = generate_generated_pkg(module_name)
  files["src/generated/schemas.mbt"] = generate_schemas_file(ir)
  files["src/generated/operations.mbt"] = generate_operations_file(ir)
  files["src/generated/contract.mbt"] = generate_contract_file(ir)
  files["src/generated/router.mbt"] = generate_router_file(ir)
  files["src/generated/client.mbt"] = generate_client_file(ir)
  files["src/handlers/moon.pkg"] = generate_handlers_pkg(module_name)
  for operation in ir.operations {
    files["src/handlers/" + operation.snake_id + ".mbt"] = generate_handler_file(
      operation,
    )
  }
  files["src/bootstrap/moon.pkg"] = generate_bootstrap_pkg(module_name)
  files["src/bootstrap/main.mbt"] = generate_bootstrap_main(ir)
  files
}

///|
fn generate_moon_mod(module_name : String) -> String {
  let builder = StringBuilder::new()
  builder.write_string("{\n")
  builder.write_string("  \"name\": \"")
  builder.write_string(module_name)
  builder.write_string("\",\n")
  builder.write_string("  \"version\": \"0.1.0\",\n")
  builder.write_string("  \"deps\": {\n")
  builder.write_string("    \"cogna-dev/mapi\": \"0.1.0\"\n")
  builder.write_string("  }\n")
  builder.write_string("}\n")
  builder.to_string()
}

///|
fn generate_generated_pkg(_module_name : String) -> String {
  let builder = StringBuilder::new()
  builder.write_string("import {\n")
  builder.write_string("  \"cogna-dev/mapi/lib\" @lib,\n")
  builder.write_string("  \"moonbitlang/core/encoding/utf8\" @utf8,\n")
  builder.write_string("  \"moonbitlang/core/json\",\n")
  builder.write_string("}\n")
  builder.to_string()
}

///|
fn generate_handlers_pkg(module_name : String) -> String {
  let builder = StringBuilder::new()
  builder.write_string("import {\n")
  builder.write_string("  \"")
  builder.write_string(module_name)
  builder.write_string("/src/generated\" @generated,\n")
  builder.write_string("  \"cogna-dev/mapi/lib\" @lib,\n")
  builder.write_string("}\n")
  builder.to_string()
}

///|
fn generate_bootstrap_pkg(module_name : String) -> String {
  let builder = StringBuilder::new()
  builder.write_string("import {\n")
  builder.write_string("  \"cogna-dev/mapi/lib\" @lib,\n")
  builder.write_string("  \"")
  builder.write_string(module_name)
  builder.write_string("/src/generated\" @generated,\n")
  builder.write_string("  \"")
  builder.write_string(module_name)
  builder.write_string("/src/handlers\" @handlers,\n")
  builder.write_string("}\n\n")
  builder.write_string("options(\n")
  builder.write_string("  \"is-main\": true,\n")
  builder.write_string(")\n")
  builder.to_string()
}

///|
fn generate_schemas_file(ir : ApiIR) -> String {
  let builder = StringBuilder::new()
  builder.write_string(generated_header)
  for schema in ir.schemas {
    builder.write_string("///|\n")
    match schema.kind {
      Object => {
        builder.write_string("pub(all) struct ")
        builder.write_string(schema.name)
        builder.write_string(" {\n")
        for field in schema.fields {
          builder.write_string("  ")
          builder.write_string(field.name)
          builder.write_string(" : ")
          builder.write_string(
            optionalize_type(field.moonbit_type, field.required),
          )
          builder.write_string("\n")
        }
        builder.write_string("} derive(ToJson, FromJson)\n\n")
      }
      StringEnum(values) => {
        builder.write_string("pub(all) enum ")
        builder.write_string(schema.name)
        builder.write_string(" {\n")
        for value in values {
          builder.write_string("  ")
          builder.write_string(pascal_case(value))
          builder.write_string("\n")
        }
        builder.write_string("} derive(ToJson, FromJson)\n\n")
      }
      Primitive(moonbit_type) => {
        builder.write_string("pub type ")
        builder.write_string(schema.name)
        builder.write_string(" = ")
        builder.write_string(moonbit_type)
        builder.write_string("\n\n")
      }
    }
  }
  builder.to_string()
}

///|
fn generate_operations_file(ir : ApiIR) -> String {
  let builder = StringBuilder::new()
  builder.write_string(generated_header)
  for operation in ir.operations {
    let input_name = operation_input_name(operation)
    builder.write_string("///|\n")
    builder.write_string("pub(all) struct ")
    builder.write_string(input_name)
    builder.write_string(" {\n")
    for parameter in operation.path_params {
      write_param_field(builder, parameter)
    }
    for parameter in operation.query_params {
      write_param_field(builder, parameter)
    }
    match operation.request_body_type {
      Some(request_type) => {
        builder.write_string("  body : ")
        builder.write_string(request_type)
        builder.write_string("\n")
      }
      None => ()
    }
    builder.write_string("} derive(ToJson, FromJson)\n\n")
    builder.write_string("///|\n")
    builder.write_string("pub(all) enum ")
    builder.write_string(operation_response_name(operation))
    builder.write_string(" {\n")
    builder.write_string("  Ok(")
    builder.write_string(operation.response_type)
    builder.write_string(")\n")
    builder.write_string("} derive(ToJson, FromJson)\n\n")
  }
  builder.to_string()
}

///|
fn write_param_field(builder : StringBuilder, parameter : ParamIR) -> Unit {
  builder.write_string("  ")
  builder.write_string(parameter.name)
  builder.write_string(" : ")
  builder.write_string(
    optionalize_type(parameter.moonbit_type, parameter.required),
  )
  builder.write_string("\n")
}

///|
fn generate_contract_file(ir : ApiIR) -> String {
  let builder = StringBuilder::new()
  builder.write_string(generated_header)
  builder.write_string("///|\n")
  builder.write_string("pub(all) struct ApiHandlers {\n")
  for operation in ir.operations {
    builder.write_string("  ")
    builder.write_string(operation.snake_id)
    builder.write_string(" : (@lib.RequestContext, ")
    builder.write_string(operation_input_name(operation))
    builder.write_string(") -> Result[")
    builder.write_string(operation_response_name(operation))
    builder.write_string(", @lib.AppError]\n")
  }
  builder.write_string("}\n")
  builder.to_string()
}

///|
fn generate_router_file(ir : ApiIR) -> String {
  let builder = StringBuilder::new()
  builder.write_string(generated_header)
  builder.write_string("///|\n")
  builder.write_string(
    "pub fn routes(_handlers : ApiHandlers) -> Array[@lib.Route] {\n",
  )
  builder.write_string("  [\n")
  for operation in ir.operations {
    builder.write_string("    { http_method: @lib.HttpMethod::")
    builder.write_string(operation.http_method)
    builder.write_string(", pattern: \"")
    builder.write_string(operation.path)
    builder.write_string(
      "\", handler: (_ctx, _req, _params) => { status: 501, headers: Map::new(), body: None } },\n",
    )
  }
  builder.write_string("  ]\n")
  builder.write_string("}\n\n")
  builder.write_string("///|\n")
  builder.write_string(
    "pub fn make_app(handlers : ApiHandlers) -> @lib.App {\n",
  )
  builder.write_string("  let router = @lib.Router::new()\n")
  builder.write_string("  for route in routes(handlers) {\n")
  builder.write_string("    router.add(route)\n")
  builder.write_string("  }\n")
  builder.write_string("  @lib.App::new(router)\n")
  builder.write_string("}\n")
  builder.to_string()
}

///|
fn generate_client_file(ir : ApiIR) -> String {
  let builder = StringBuilder::new()
  builder.write_string(generated_header)
  builder.write_string("///|\n")
  builder.write_string("pub(all) struct ApiTransport {\n")
  builder.write_string(
    "  send : (@lib.RequestEnvelope) -> Result[@lib.ResponseEnvelope, @lib.AppError]\n",
  )
  builder.write_string("}\n\n")
  builder.write_string("///|\n")
  builder.write_string("pub(all) struct ApiClient {\n")
  builder.write_string("  transport : ApiTransport\n")
  builder.write_string("  base_path : String\n")
  builder.write_string("  default_headers : Map[String, String]\n")
  builder.write_string("}\n\n")
  builder.write_string("///|\n")
  builder.write_string("pub fn ApiClient::new(\n")
  builder.write_string("  transport : ApiTransport,\n")
  builder.write_string("  base_path~ : String = \"\",\n")
  builder.write_string("  default_headers~ : Map[String, String] = Map::new(),\n")
  builder.write_string(") -> ApiClient {\n")
  builder.write_string("  { transport, base_path, default_headers }\n")
  builder.write_string("}\n\n")
  builder.write_string("///|\n")
  builder.write_string("fn copy_headers(source : Map[String, String]) -> Map[String, String] {\n")
  builder.write_string("  let headers = Map::new()\n")
  builder.write_string("  for key, value in source {\n")
  builder.write_string("    headers[key] = value\n")
  builder.write_string("  }\n")
  builder.write_string("  headers\n")
  builder.write_string("}\n\n")
  builder.write_string("///|\n")
  builder.write_string("fn join_paths(base_path : String, route_path : String) -> String {\n")
  builder.write_string("  if base_path.is_empty() {\n")
  builder.write_string("    route_path\n")
  builder.write_string("  } else if route_path.is_empty() {\n")
  builder.write_string("    base_path\n")
  builder.write_string("  } else if base_path.has_suffix(\"/\") && route_path.has_prefix(\"/\") {\n")
  builder.write_string("    base_path + route_path.sub(start=1)\n")
  builder.write_string("  } else if !base_path.has_suffix(\"/\") && !route_path.has_prefix(\"/\") {\n")
  builder.write_string("    base_path + \"/\" + route_path\n")
  builder.write_string("  } else {\n")
  builder.write_string("    base_path + route_path\n")
  builder.write_string("  }\n")
  builder.write_string("}\n\n")
  builder.write_string("///|\n")
  builder.write_string("fn replace_path_param(path : String, param_name : String, value : String) -> String {\n")
  builder.write_string("  let token = \"{\" + param_name + \"}\"\n")
  builder.write_string("  let parts = path.split(token).to_array()\n")
  builder.write_string("  if parts.length() <= 1 {\n")
  builder.write_string("    path\n")
  builder.write_string("  } else {\n")
  builder.write_string("    parts.join(value)\n")
  builder.write_string("  }\n")
  builder.write_string("}\n\n")
  builder.write_string("///|\n")
  builder.write_string("fn app_error_from_status(status : Int) -> @lib.AppError {\n")
  builder.write_string("  match status {\n")
  builder.write_string(
    "    400 => @lib.AppError::BadRequest(\"Remote service returned 400\")\n",
  )
  builder.write_string("    401 => @lib.AppError::Unauthorized\n")
  builder.write_string("    403 => @lib.AppError::Forbidden\n")
  builder.write_string(
    "    404 => @lib.AppError::NotFound(\"Remote service returned 404\")\n",
  )
  builder.write_string(
    "    _ => @lib.AppError::Internal(\"Remote service returned unexpected status: \" + status.to_string())\n",
  )
  builder.write_string("  }\n")
  builder.write_string("}\n\n")
  for operation in ir.operations {
    write_client_method(builder, operation)
  }
  builder.to_string()
}

///|
fn write_client_method(builder : StringBuilder, operation : OperationIR) -> Unit {
  let input_name = operation_input_name(operation)
  let response_name = operation_response_name(operation)
  builder.write_string("///|\n")
  builder.write_string("pub fn ApiClient::")
  builder.write_string(operation.snake_id)
  builder.write_string("(\n")
  builder.write_string("  self : ApiClient,\n")
  builder.write_string("  input : ")
  builder.write_string(input_name)
  builder.write_string(",\n")
  builder.write_string(") -> Result[")
  builder.write_string(response_name)
  builder.write_string(", @lib.AppError] {\n")
  builder.write_string("  let headers = copy_headers(self.default_headers)\n")
  builder.write_string("  let query : Map[String, Array[String]] = Map::new()\n")
  builder.write_string("  let mut route_path = \"")
  builder.write_string(operation.path)
  builder.write_string("\"\n")
  for path_param in operation.path_params {
    builder.write_string("  route_path = replace_path_param(route_path, \"")
    builder.write_string(path_param.name)
    builder.write_string("\", ")
    builder.write_string(stringify_value("input." + path_param.name, path_param.moonbit_type))
    builder.write_string(")\n")
  }
  for query_param in operation.query_params {
    if query_param.required {
      builder.write_string("  query[\"")
      builder.write_string(query_param.name)
      builder.write_string("\"] = [")
      builder.write_string(
        stringify_value("input." + query_param.name, query_param.moonbit_type),
      )
      builder.write_string("]\n")
    } else {
      builder.write_string("  match input.")
      builder.write_string(query_param.name)
      builder.write_string(" {\n")
      builder.write_string("    Some(value) => query[\"")
      builder.write_string(query_param.name)
      builder.write_string("\"] = [")
      builder.write_string(stringify_value("value", query_param.moonbit_type))
      builder.write_string("]\n")
      builder.write_string("    None => ()\n")
      builder.write_string("  }\n")
    }
  }
  match operation.request_body_type {
    Some(_) => {
      builder.write_string("  headers[\"content-type\"] = \"application/json\"\n")
      builder.write_string(
        "  let body = Some(@utf8.encode(input.body.to_json().stringify()))\n",
      )
    }
    None => {
      builder.write_string("  let body : Bytes? = None\n")
    }
  }
  builder.write_string("  let req : @lib.RequestEnvelope = {\n")
  builder.write_string("    http_method: @lib.HttpMethod::")
  builder.write_string(operation.http_method)
  builder.write_string(",\n")
  builder.write_string("    path: join_paths(self.base_path, route_path),\n")
  builder.write_string("    query,\n")
  builder.write_string("    headers,\n")
  builder.write_string("    body,\n")
  builder.write_string("  }\n")
  builder.write_string("  let response = match (self.transport.send)(req) {\n")
  builder.write_string("    Ok(resp) => resp\n")
  builder.write_string("    Err(err) => return Err(err)\n")
  builder.write_string("  }\n")
  match operation.success_status {
    Some(status_code) => {
      builder.write_string("  if response.status != ")
      builder.write_string(status_code)
      builder.write_string(" {\n")
      builder.write_string("    return Err(app_error_from_status(response.status))\n")
      builder.write_string("  }\n")
    }
    None => {
      builder.write_string(
        "  if response.status < 200 || response.status >= 300 {\n",
      )
      builder.write_string("    return Err(app_error_from_status(response.status))\n")
      builder.write_string("  }\n")
    }
  }
  if operation.response_type == "Unit" {
    builder.write_string("  Ok(")
    builder.write_string(response_name)
    builder.write_string("::Ok(()))\n")
    builder.write_string("}\n\n")
    return
  }
  builder.write_string("  let response_body = match response.body {\n")
  builder.write_string("    Some(bytes) => @utf8.decode_lossy(bytes.view())\n")
  builder.write_string(
    "    None => return Err(@lib.AppError::BadRequest(\"Missing response body\"))\n",
  )
  builder.write_string("  }\n")
  builder.write_string("  let parsed = @json.parse(response_body) catch {\n")
  builder.write_string(
    "    _ => return Err(@lib.AppError::BadRequest(\"Invalid JSON response body\"))\n",
  )
  builder.write_string("  }\n")
  builder.write_string("  let decoded : ")
  builder.write_string(operation.response_type)
  builder.write_string(" = @json.from_json(parsed) catch {\n")
  builder.write_string(
    "    _ => return Err(@lib.AppError::BadRequest(\"Response body does not match generated static type\"))\n",
  )
  builder.write_string("  }\n")
  builder.write_string("  Ok(")
  builder.write_string(response_name)
  builder.write_string("::Ok(decoded))\n")
  builder.write_string("}\n\n")
}

///|
fn stringify_value(expression : String, moonbit_type : String) -> String {
  match moonbit_type {
    "String" => expression
    "Int" => expression + ".to_string()"
    "Double" => expression + ".to_string()"
    "Bool" => expression + ".to_string()"
    _ => expression + ".to_json().stringify()"
  }
}

///|
fn generate_handler_file(operation : OperationIR) -> String {
  let builder = StringBuilder::new()
  builder.write_string(user_header)
  builder.write_string("///|\n")
  builder.write_string("pub fn ")
  builder.write_string(operation.snake_id)
  builder.write_string("(\n")
  builder.write_string("  _ctx : @lib.RequestContext,\n")
  builder.write_string("  _input : @generated.")
  builder.write_string(operation_input_name(operation))
  builder.write_string(",\n")
  builder.write_string(") -> Result[@generated.")
  builder.write_string(operation_response_name(operation))
  builder.write_string(", @lib.AppError] {\n")
  builder.write_string("  Err(@lib.AppError::Internal(\"not implemented\"))\n")
  builder.write_string("}\n")
  builder.to_string()
}

///|
fn generate_bootstrap_main(ir : ApiIR) -> String {
  let builder = StringBuilder::new()
  builder.write_string(user_header)
  builder.write_string("///|\n")
  builder.write_string("fn main {\n")
  builder.write_string("  let handlers : @generated.ApiHandlers = {\n")
  for operation in ir.operations {
    builder.write_string("    ")
    builder.write_string(operation.snake_id)
    builder.write_string(": @handlers.")
    builder.write_string(operation.snake_id)
    builder.write_string(",\n")
  }
  builder.write_string("  }\n")
  builder.write_string("  ignore(@generated.make_app(handlers))\n")
  builder.write_string("}\n")
  builder.to_string()
}

///|
fn operation_input_name(operation : OperationIR) -> String {
  pascal_case(operation.operation_id) + "Input"
}

///|
fn operation_response_name(operation : OperationIR) -> String {
  pascal_case(operation.operation_id) + "Response"
}

///|
fn optionalize_type(base_type : String, required : Bool) -> String {
  if required {
    base_type
  } else {
    base_type + "?"
  }
}
